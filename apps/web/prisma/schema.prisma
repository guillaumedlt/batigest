generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// UTILISATEUR & ENTREPRISE
// ============================================

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  authId    String   @unique // Supabase Auth UID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entreprise Entreprise?
  contacts   Contact[]
  devis      Devis[]
  factures   Facture[]
  achats     FicheAchat[]
  evenements Evenement[]
  notesFrais NoteFrais[]
  miniSite   MiniSite?

  @@map("users")
}

model Entreprise {
  id                    String  @id @default(uuid()) @db.Uuid
  userId                String  @unique @db.Uuid
  user                  User    @relation(fields: [userId], references: [id])
  nomEntreprise         String
  formeJuridique        String? // SARL, SAS, EI, micro-entreprise
  siret                 String?
  rcsRm                 String? // RCS ou Repertoire des Metiers
  tvaIntracom           String? // Numero TVA intracommunautaire
  adresse               String
  codePostal            String
  ville                 String
  telephone             String
  email                 String
  logoUrl               String?
  metier                String? // Electricien, Plombier, Macon...
  assuranceDecennale    String? // Nom de l'assureur
  assuranceNumero       String? // Numero de police
  assuranceZone         String? // Zone de couverture
  franchiseTVA          Boolean @default(false) // Auto-entrepreneur / micro-entreprise
  regimeTVA             String  @default("FRANCHISE") // FRANCHISE, REEL_SIMPLIFIE, REEL_NORMAL
  conditionsReglement   String? // Conditions par defaut
  mentionsDevis         String? // Mentions additionnelles devis
  mentionsFacture       String? // Mentions additionnelles factures
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Sequences pour numerotation
  sequenceDevis   Int @default(0)
  sequenceFacture Int @default(0)
  sequenceAvoir   Int @default(0)

  @@map("entreprises")
}

// ============================================
// MODULE 1 — REPERTOIRE / CRM
// ============================================

model Contact {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @db.Uuid
  user        User        @relation(fields: [userId], references: [id])
  type        ContactType
  nom         String
  prenom      String?
  entreprise  String?
  telephone   String
  email       String?
  adresse     String?
  codePostal  String?
  ville       String?
  siret       String?
  notes       String?
  tags        String[]    @default([])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?   // Soft delete

  devis       Devis[]
  factures    Facture[]
  achats      FicheAchat[]
  evenements  Evenement[]

  @@index([userId, type])
  @@index([userId, nom])
  @@map("contacts")
}

enum ContactType {
  CLIENT
  PROSPECT
  FOURNISSEUR
  SOUS_TRAITANT
}

// ============================================
// MODULE 2 — DEVIS
// ============================================

model Devis {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  user          User        @relation(fields: [userId], references: [id])
  contactId     String      @db.Uuid
  contact       Contact     @relation(fields: [contactId], references: [id])
  numero        String      @unique // D-2026-001
  objet         String
  dateCreation  DateTime    @default(now())
  dateValidite  DateTime
  statut        DevisStatut @default(BROUILLON)
  totalHT       Decimal     @db.Decimal(12, 2)
  totalTVA      Decimal     @db.Decimal(12, 2)
  totalTTC      Decimal     @db.Decimal(12, 2)
  remise        Decimal?    @db.Decimal(12, 2) // Remise globale
  conditions    String?
  notes         String?
  signatureUrl  String?
  signedAt      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  lignes        DevisLigne[]
  factures      Facture[]   // Factures generees depuis ce devis

  @@index([userId, statut])
  @@index([userId, dateCreation])
  @@map("devis")
}

model DevisLigne {
  id              String  @id @default(uuid()) @db.Uuid
  devisId         String  @db.Uuid
  devis           Devis   @relation(fields: [devisId], references: [id], onDelete: Cascade)
  designation     String
  description     String?
  quantite        Decimal @db.Decimal(10, 3)
  unite           String  // h, m2, forfait, u...
  prixUnitaireHT  Decimal @db.Decimal(12, 2)
  tauxTVA         Decimal @db.Decimal(4, 2) // 5.50, 10.00, 20.00
  totalHT         Decimal @db.Decimal(12, 2)
  lot             String? // Regroupement par lot (batiment)
  ordre           Int

  @@index([devisId])
  @@map("devis_lignes")
}

enum DevisStatut {
  BROUILLON
  ENVOYE
  ACCEPTE
  REFUSE
  EXPIRE
}

// ============================================
// MODULE 3 — FACTURATION
// ============================================

model Facture {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @db.Uuid
  user            User          @relation(fields: [userId], references: [id])
  contactId       String        @db.Uuid
  contact         Contact       @relation(fields: [contactId], references: [id])
  devisId         String?       @db.Uuid
  devis           Devis?        @relation(fields: [devisId], references: [id])
  numero          String        @unique // F-2026-001 ou A-2026-001
  type            FactureType
  dateEmission    DateTime      @default(now())
  dateEcheance    DateTime
  dateExecution   DateTime?     // Date de livraison/execution
  statut          FactureStatut @default(BROUILLON)
  totalHT         Decimal       @db.Decimal(12, 2)
  totalTVA        Decimal       @db.Decimal(12, 2)
  totalTTC        Decimal       @db.Decimal(12, 2)
  montantPaye     Decimal       @default(0) @db.Decimal(12, 2)
  resteARegler    Decimal       @db.Decimal(12, 2)
  conditions      String?
  notes           String?
  pourcentage     Decimal?      @db.Decimal(5, 2) // Pour acomptes/situations
  factureParentId String?       @db.Uuid // Pour avoirs
  factureParent   Facture?      @relation("AvoirFacture", fields: [factureParentId], references: [id])
  avoirs          Facture[]     @relation("AvoirFacture")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  lignes          FactureLigne[]
  paiements       Paiement[]

  @@index([userId, statut])
  @@index([userId, dateEmission])
  @@map("factures")
}

model FactureLigne {
  id              String  @id @default(uuid()) @db.Uuid
  factureId       String  @db.Uuid
  facture         Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)
  designation     String
  description     String?
  quantite        Decimal @db.Decimal(10, 3)
  unite           String
  prixUnitaireHT  Decimal @db.Decimal(12, 2)
  tauxTVA         Decimal @db.Decimal(4, 2)
  totalHT         Decimal @db.Decimal(12, 2)
  lot             String?
  avancement      Decimal? @db.Decimal(5, 2) // Pour factures de situation (%)
  ordre           Int

  @@index([factureId])
  @@map("facture_lignes")
}

model Paiement {
  id        String   @id @default(uuid()) @db.Uuid
  factureId String   @db.Uuid
  facture   Facture  @relation(fields: [factureId], references: [id])
  montant   Decimal  @db.Decimal(12, 2)
  date      DateTime
  mode      String   // virement, cheque, especes, CB
  reference String?
  notes     String?
  createdAt DateTime @default(now())

  @@index([factureId])
  @@map("paiements")
}

enum FactureType {
  CLASSIQUE
  ACOMPTE
  SITUATION
  AVOIR
}

enum FactureStatut {
  BROUILLON
  EMISE
  PAYEE_PARTIELLEMENT
  PAYEE
  ANNULEE
}

// ============================================
// MODULE 4 — FICHES D'ACHAT
// ============================================

model FicheAchat {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @db.Uuid
  user          User            @relation(fields: [userId], references: [id])
  fournisseurId String?         @db.Uuid
  fournisseur   Contact?        @relation(fields: [fournisseurId], references: [id])
  date          DateTime
  designation   String
  categorie     CategorieAchat
  montantHT     Decimal         @db.Decimal(12, 2)
  tauxTVA       Decimal         @db.Decimal(4, 2)
  montantTTC    Decimal         @db.Decimal(12, 2)
  photoUrl      String?
  notes         String?
  chantierId    String?         // Reference libre au chantier
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@index([userId, date])
  @@index([userId, categorie])
  @@map("fiches_achat")
}

enum CategorieAchat {
  MATERIAUX
  OUTILLAGE
  LOCATION
  SOUS_TRAITANCE
  AUTRE
}

// ============================================
// MODULE 6 — CALENDRIER
// ============================================

model Evenement {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @db.Uuid
  user           User          @relation(fields: [userId], references: [id])
  titre          String
  type           EvenementType
  dateDebut      DateTime
  dateFin        DateTime
  journeeEntiere Boolean       @default(false)
  contactId      String?       @db.Uuid
  contact        Contact?      @relation(fields: [contactId], references: [id])
  adresse        String?
  notes          String?
  rappel         Int?          // Minutes avant l'evenement
  couleur        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([userId, dateDebut])
  @@map("evenements")
}

enum EvenementType {
  CHANTIER
  RDV_CLIENT
  RDV_FOURNISSEUR
  RELANCE
  PERSO
}

// ============================================
// MODULE 7 — NOTES DE FRAIS
// ============================================

model NoteFrais {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @db.Uuid
  user        User          @relation(fields: [userId], references: [id])
  date        DateTime
  categorie   CategorieNote
  montant     Decimal       @db.Decimal(12, 2)
  tva         Decimal?      @db.Decimal(12, 2)
  description String
  photoUrl    String?
  chantierId  String?
  km          Decimal?      @db.Decimal(8, 1) // Pour indemnites km
  remboursee  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@index([userId, date])
  @@map("notes_frais")
}

enum CategorieNote {
  CARBURANT
  PEAGE
  RESTAURANT
  FOURNITURES
  PARKING
  KILOMETRIQUE
  AUTRE
}

// ============================================
// MODULE 8 — MINI-SITE VITRINE
// ============================================

model MiniSite {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @unique @db.Uuid
  user              User          @relation(fields: [userId], references: [id])
  slug              String        @unique // URL-friendly
  nomEntreprise     String
  metier            String
  description       String?
  telephone         String
  email             String
  adresse           String?
  zoneIntervention  String?
  logoUrl           String?
  theme             MiniSiteTheme @default(BLEU)
  certifications    String[]      @default([])
  competences       String[]      @default([]) // Electricite, Plomberie, Peinture...
  prestations       String[]      @default([]) // Renovation complete, Mise aux normes...
  anneesExperience  Int?
  slogan            String?       // "Votre electricien de confiance depuis 2010"
  horaires          String?       // "Lun-Ven 8h-18h"
  siteWeb           String?       // Lien externe si existant
  actif             Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  photos            MiniSitePhoto[]
  avis              MiniSiteAvis[]

  @@map("mini_sites")
}

model MiniSitePhoto {
  id          String   @id @default(uuid()) @db.Uuid
  miniSiteId  String   @db.Uuid
  miniSite    MiniSite @relation(fields: [miniSiteId], references: [id], onDelete: Cascade)
  url         String
  legende     String?
  ordre       Int
  avantApres  Boolean  @default(false) // Photo avant/apres

  @@index([miniSiteId])
  @@map("mini_site_photos")
}

model MiniSiteAvis {
  id          String   @id @default(uuid()) @db.Uuid
  miniSiteId  String   @db.Uuid
  miniSite    MiniSite @relation(fields: [miniSiteId], references: [id], onDelete: Cascade)
  auteur      String
  note        Int      // 1-5
  commentaire String
  date        DateTime
  valide      Boolean  @default(false) // Moderation
  createdAt   DateTime @default(now())

  @@index([miniSiteId])
  @@map("mini_site_avis")
}

enum MiniSiteTheme {
  BLEU
  VERT
  ORANGE
  GRIS
}

// ============================================
// BIBLIOTHEQUE DE PRESTATIONS (reutilisables)
// ============================================

model Prestation {
  id              String  @id @default(uuid()) @db.Uuid
  userId          String  @db.Uuid
  designation     String
  description     String?
  unite           String
  prixUnitaireHT  Decimal @db.Decimal(12, 2)
  tauxTVA         Decimal @db.Decimal(4, 2)
  categorie       String? // Categorie libre
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("prestations")
}
